# Copy to .env and fill in from Firebase Console → Project settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics only — not required for flashcards)
# VITE_FIREBASE_MEASUREMENT_ID=

# GitHub Pages only: set to /repository-name/ (slashes required). Leave as / for local dev.
# VITE_BASE_PATH=/cursor_2/
